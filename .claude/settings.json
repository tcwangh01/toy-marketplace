{
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type":"command",
            "command": "node .claude/hooks/notification_hook.ts --sound_effect_file"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type":"command",
            "command": "node .claude/hooks/lint_hook.ts"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/test_runner_hook.ts"
          }
        ]
      }
    ]
  }
}
